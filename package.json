{
  "name": "simple-todolist-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn build:shared && concurrently -n web,api -c blue,green \"yarn workspace @task-app/web dev\" \"yarn workspace @task-app/api dev\"",
    "dev:web": "yarn build:shared && yarn workspace @task-app/web dev",
    "dev:api": "yarn build:shared && yarn workspace @task-app/api dev",
    "build": "yarn build:shared && yarn build:api && yarn build:web",
    "build:shared": "yarn workspace @task-app/shared build",
    "build:web": "yarn build:shared && yarn workspace @task-app/web build",
    "build:api": "yarn build:shared && yarn workspace @task-app/api build",
    "test": "yarn workspaces run test",
    "lint": "yarn workspaces run lint",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=100",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:generate": "yarn workspace @task-app/api db:generate",
    "db:migrate": "yarn workspace @task-app/api db:migrate",
    "db:studio": "yarn workspace @task-app/api db:studio",
    "db:seed": "yarn workspace @task-app/api db:seed",
    "db:reset": "yarn workspace @task-app/api db:reset",
    "scripts": "echo \"Available scripts: dev, dev:web, dev:api, build, build:shared, build:web, build:api, test, lint, docker:up, docker:down, docker:logs, db:up, db:down, db:generate, db:migrate, db:studio, db:seed, db:reset\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4"
  }
}
